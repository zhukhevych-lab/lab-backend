{
    "name": "backend",
    "version": "1.0.0",
    "description": "Express backend API with TypeScript",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint .",
        "format": "prettier -w .",
        "seed": "tsx src/db/seed.ts"
    },
    "keywords": [
