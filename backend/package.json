    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.1",
        "@types/sqlite3": "^3.1.11",
        "@typescript-eslint/eslint-plugin": "^8.59.2",
        "@typescript-eslint/parser": "^8.59.2",
        "eslint": "^8.57.1",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    }
